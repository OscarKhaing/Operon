# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ── LLM Provider ──
# "gemini" (default) or "ollama"
LLM_PROVIDER=gemini

# ── Google Gemini (cloud LLM) ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local LLM) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── MongoDB API (Express server) ──
MONGODB_API_URL=http://localhost:5001

# ── Resend (email dispatch to hotels) ──
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_PLACEHOLDER_paste_your_key_here

# Sender address — must be verified in Resend dashboard.
# Use onboarding@resend.dev for sandbox testing.
RESEND_FROM=reservations@updates.clerkless.store
